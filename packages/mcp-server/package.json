{
  "name": "@aime/mcp-server",
  "version": "0.1.0",
  "description": "MCP server that serves human context to AI providers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "aime-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "start": "tsx src/index.ts",
    "start:http": "tsx src/http.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aime/schema": "workspace:*",
    "@aime/vault": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^4.3.6"
  },
  "files": [
    "dist"
  ]
}
